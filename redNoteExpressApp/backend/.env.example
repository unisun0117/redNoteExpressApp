# 数据库地址（本地用 SQLite，云端用 PostgreSQL）
# Neon.tech 或 Render 会提供 PostgreSQL 连接地址
DATABASE_URL=sqlite:///./rednote.db

# JWT 密钥（生产环境务必改成随机字符串）
JWT_SECRET=dev-secret-change-in-production

# OpenAI API 密钥
OPENAI_API_KEY=sk-your-key-here

# Anthropic API 密钥（可选）
ANTHROPIC_API_KEY=

# AI 模型配置
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o

# CORS 允许的前端域名（多个用逗号分隔）
ALLOWED_ORIGINS=http://localhost:5173

# Redis 地址（目前未使用）
REDIS_URL=redis://localhost:6379/0

# 微信小程序（目前未使用）
WECHAT_APP_ID=
WECHAT_APP_SECRET=
